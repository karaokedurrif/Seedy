# ── Together.ai (clasificador + fallback) ────────────
TOGETHER_API_KEY=your-together-api-key-here
TOGETHER_MODEL_ID=Qwen/Qwen2.5-7B-Instruct-Turbo
TOGETHER_CLASSIFIER_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo
TOGETHER_BASE_URL=https://api.together.xyz/v1

# ── Ollama (principal — modelo fine-tuned local) ─────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=seedy:q8
OLLAMA_EMBED_MODEL=mxbai-embed-large

# ── Qdrant ──────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── RAG ─────────────────────────────────────────────
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=300
RAG_TOP_K=8
RAG_BM25_WEIGHT=0.7
RAG_RELEVANCE_THRESHOLD=0.25
RAG_RERANK_TOP_N=3

# ── Backend ─────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=info
# URL pública del backend Seedy (usada para URLs absolutas de cámaras en API OvoSfera)
SEEDY_BACKEND_URL=https://seedy-api.neofarm.io

# ── Seguridad (contraseñas de servicios) ────────────
INFLUXDB_USERNAME=neofarm
INFLUXDB_PASSWORD=cambia-esta-password
INFLUXDB_ORG=neofarm
INFLUXDB_BUCKET=porcidata
GRAFANA_ADMIN_PASSWORD=cambia-esta-password

# ── Telegram alertas (opcional) ─────────────────────
# TELEGRAM_BOT_TOKEN=tu-bot-token
# TELEGRAM_CHAT_ID=tu-chat-id
